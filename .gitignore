# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Test coverage
coverage/

# Playwright browsers (kept inside project via PLAYWRIGHT_BROWSERS_PATH=0)
.local-browsers/

# Internal working artifacts (e.g. review notes) — never published.
# The canonical copies live under .internal/reviews/. The explicit names guard
# against the iCloud-synced folder restoring stray copies at the repo root.
.internal/
CODEX_WAVE0_REVIEW.md
CLAUDE_WAVE0_SELF_REVIEW.md

# Temporary test output (kept inside the project, never committed)
.tmp-test/

# Ephemeral scan reports (artifacts, not source)
reports/*
!reports/.gitkeep

# NOTE: the curated public demo snapshot under
# apps/report-viewer/public/report/ is intentionally COMMITTED, so the viewer has
# something to render without a scan. Only ephemeral scans under reports/ are ignored.

# Environment / local
.env
.env.*
*.local

# OS / editor
.DS_Store
Thumbs.db
